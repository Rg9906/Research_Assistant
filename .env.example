# ---- LLM Configuration ----
# Preferred provider: "openai", "gemini" (alias: "google"), or "groq".
# This is a preference, not a requirement: PaperPilot tries this provider first
# and then falls back to any other provider below that has an API key, so a
# missing or broken key degrades chat instead of taking the app down.
# Set the keys for every provider you want available as a fallback.
LLM_PROVIDER=openai

OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL_NAME=gpt-4o-mini
RAG_LLM_MODEL=gpt-4o-mini

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# ---- Grounded QA ----
# Route chat through the Tutor/Critic contract: answers are written only from
# retrieved chunks, then audited for grounding/relevance/style and retried if
# rejected. Set to false to use LlamaIndex's default chat prompts instead.
RAG_GROUNDED_QA_ENABLED=true
# Each retry costs two more LLM calls (tutor + critic).
RAG_MAX_CRITIQUE_RETRIES=2
# The audit re-sends the whole context, so it roughly DOUBLES tokens per answer.
# On a small per-minute quota (e.g. Groq's free tier: 6000 tokens/minute) set
# this to false. Answers stay grounded and still refuse when unsupported —
# they are just not independently checked.
RAG_CRITIQUE_ENABLED=true
# Chunks retrieved per summary. Lower this too if you hit token limits.
RAG_SUMMARY_TOP_K=6

# ---- Academic Search APIs ----
# Semantic Scholar (free, but rate-limited without a key)
# Request one at: https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=your-semantic-scholar-key-here
# Requests are paced client-side to this rate. The standard key grant is 1 rps;
# only raise this if Semantic Scholar granted your key a higher quota.
SEMANTIC_SCHOLAR_RATE_LIMIT_RPS=1.0
SEMANTIC_SCHOLAR_MAX_RETRIES=2

# ---- Embedding Model ----
# Used locally via sentence-transformers (no API key needed for local models)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
